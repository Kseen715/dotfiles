#!/bin/sh
# osr — front-end CLI for the os-rice harness.
#
#   osr install <rice> [--user <name>] [--verbose]   full install of a rice
#   osr switch  <rice> [--user <name>] [--verbose]   move to a rice (§6):
#                                                    additive packages, the
#                                                    rice-owned 90-* config and
#                                                    wallpaper are replaced;
#                                                    00-env / aliases / installed
#                                                    packages are left untouched.
#   osr module  <name>... [--user <name>]            install module(s), no rice
#   osr list                                         list available rices
#   osr modules                                      list available modules
#
# switch and install share one idempotent engine (install.sh): because installs
# never uninstall and install_layer overwrites only os-rice-owned layers, "move
# A -> B" is just applying B on top of A.
set -eu

OSR_SELF_DIR=$(cd -- "$(dirname -- "$0")" && pwd)
_cmd=${1:-}
[ $# -gt 0 ] && shift

case "$_cmd" in
    install) exec "$OSR_SELF_DIR/install.sh" "$@" ;;
    switch)  OSR_MODE=switch; export OSR_MODE; exec "$OSR_SELF_DIR/install.sh" "$@" ;;
    module)  exec "$OSR_SELF_DIR/install.sh" --module "$@" ;;
    list)    exec "$OSR_SELF_DIR/install.sh" --list ;;
    modules) exec "$OSR_SELF_DIR/install.sh" --list-modules ;;
    -h|--help|"")
        sed -n '2,17p' "$0" | sed 's/^# \{0,1\}//'
        ;;
    *)
        echo "osr: unknown command '$_cmd' (try: install, switch, module, list, modules)" >&2
        exit 1
        ;;
esac
