# gruvbox — shell + KDE/Plasma gruvbox desktop rice. One line per module; add an
# app = add a line. See DESIGN "Manifest format".
zsh

# Rice-owned XDG theme config, copied to ~/.config on install/switch (§5/§6).
# GTK theme selection, font rendering, and xsettings for GTK apps under KDE.
# The KDE global theme, icon pack, and wallpapers are store/URL downloads — see
# README.md; they are intentionally not vendored here.
config: gtk-4.0 fontconfig xsettingsd
